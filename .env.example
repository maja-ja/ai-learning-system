# Etymon Decoder 後端環境變數
# 複製為 .env 後填入真值；.env 已在 .gitignore，不會被提交

# ── AI 供應商（至少設一個）──
GEMINI_API_KEY=
# ANTHROPIC_API_KEY=

# AI_PROVIDER=auto           # auto | gemini | claude
# GEMINI_MODEL=gemini-2.5-flash
# CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ── Supabase（選填；不設則僅用本機 SQLite）──
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── 安全（正式環境必改）──
APP_PASSWORD=abcd
EXAM_TOKEN_SECRET=dev-exam-secret-change-me
# MEMBERSHIP_TOKEN_SECRET=與_kadusella_相同

# ── 其他 ──
# ALLOW_DEV_DEFAULTS=1       # 本機開發時設 1 跳過密碼警告
# LOCK_AI_FEATURES=false
# LOG_LEVEL=INFO
